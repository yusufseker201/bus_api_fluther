{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Bus App Backend",
      "type": "shell",
      "command": "./scripts/start_backend.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[1/5\\] Flutter dependencies",
          "endsPattern": "Starting development server at http://127\\.0\\.0\\.1:8000/"
        }
      }
    },
    {
      "label": "Start Bus App Backend 8010",
      "type": "shell",
      "command": "./scripts/health_check.sh && cd ../bus_api && ./venv/bin/python manage.py runserver 127.0.0.1:8010",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "custom",
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 1,
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[1/5\\] Flutter dependencies",
          "endsPattern": "Starting development server at http://127\\.0\\.0\\.1:8010/"
        }
      }
    }
  ]
}
